<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="1080.0" prefWidth="1920.0" styleClass="gallery-root" stylesheets="@Gallery.css" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GalleryController">

    <!-- Header Navigation -->
    <HBox styleClass="header-nav">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label style="-fx-font-size: 18px;" text="🔍" textFill="WHITE" />
            <Label styleClass="nav-title" text="Animo Found" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <HBox styleClass="nav-links">
            <Button onAction="#goToDashboard" styleClass="nav-link" text="Dashboard" />
            <Button onAction="#goToReportItem" styleClass="nav-link" text="Report Item" />
            <Button styleClass="nav-link,active" text="Gallery" />
            <Button onAction="#logout" styleClass="nav-link,logout" text="🚪 Logout" />
        </HBox>
    </HBox>

    <!-- Main Content ScrollPane -->
    <ScrollPane fitToWidth="true" styleClass="main-scroll" VBox.vgrow="ALWAYS">
        <VBox styleClass="main-content">

            <!-- Page Header -->
            <VBox styleClass="page-header">
                <Label styleClass="page-title" text="All Reported Lost and Found Items" />
                <Label styleClass="page-subtitle" text="Browse through all reported items and help reunite lost belongings with their owners." />
            </VBox>

            <!-- Search and Filters -->
            <VBox styleClass="search-filter-section">
                <HBox styleClass="filters-row">
                    <TextField fx:id="searchField" promptText="Search items..." styleClass="search-field" />
                    <ComboBox fx:id="categoryFilter" promptText="All Categories" styleClass="filter-dropdown" />
                    <ComboBox fx:id="locationFilter" promptText="All Locations" styleClass="filter-dropdown" />
                    <ComboBox fx:id="sortFilter" promptText="Newest First" styleClass="filter-dropdown" />
                    <Button onAction="#refreshGallery" styleClass="refresh-button" text="🔄 Refresh" />
                </HBox>
            </VBox>

            <!-- Gallery Grid -->
            <TilePane fx:id="galleryPane" styleClass="gallery-grid" VBox.vgrow="ALWAYS" />

            <!-- Pagination -->
            <HBox fx:id="paginationContainer" styleClass="pagination-container">
                <Button fx:id="prevButton" onAction="#previousPage" styleClass="pagination-arrow" text="‹" />
                <Button fx:id="page1" onMouseClicked="#goToPage" styleClass="pagination-button,active" text="1" textFill="#05451c" />
                <Button fx:id="page2" onMouseClicked="#goToPage" styleClass="pagination-button" text="2" />
                <Button fx:id="page3" onMouseClicked="#goToPage" styleClass="pagination-button" text="3" />
                <Label style="-fx-text-fill: #6c757d;" text="..." />
                <Button fx:id="page10" onMouseClicked="#goToPage" styleClass="pagination-button" text="10" />
                <Button fx:id="nextButton" onAction="#nextPage" styleClass="pagination-arrow" text="›" />
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- Footer - Fixed at bottom -->
    <VBox styleClass="footer-section">
        <HBox spacing="80" styleClass="footer-content">

            <!-- Brand Column -->
            <VBox styleClass="footer-column">
                <Label styleClass="footer-brand" text="Animo Found" />
                <Label styleClass="footer-description" text="Helping DLSU community reunite with their lost belongings." />
            </VBox>

            <!-- Quick Links Column -->
            <VBox styleClass="footer-column">
                <Label styleClass="footer-heading" text="Quick Links" />
                <Label styleClass="footer-link" text="Report Lost Item" />
                <Label styleClass="footer-link" text="Browse Found Items" />
                <Label styleClass="footer-link" text="How It Works" />
            </VBox>

            <!-- Contact Column -->
            <VBox styleClass="footer-column">
                <Label styleClass="footer-heading" text="Contact" />
                <Label styleClass="footer-contact" text="security@dlsu.edu.ph" />
                <Label styleClass="footer-contact" text="(02) 8524-4611" />
            </VBox>

        </HBox>

        <!-- Footer Bottom -->
        <VBox styleClass="footer-bottom">
            <Label styleClass="footer-copyright" text="© 2025 Animo Found. All rights reserved." />
        </VBox>
    </VBox>

</VBox>
