<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.SignUpController"
      stylesheets="@signup.css"
      styleClass="main-container"
      alignment="CENTER"
      spacing="0">

    <children>
        <!-- Spacer to push content to center -->
        <Region VBox.vgrow="ALWAYS" />

        <!-- Main Content Container -->
        <VBox alignment="CENTER" spacing="40">
            <children>
                <!-- Header Section -->
                <VBox alignment="CENTER" styleClass="header-section" spacing="20">
                    <children>
                        <!-- DLSU Logo (without container background) -->
                        <ImageView fx:id="dlsuLogo" fitHeight="100" fitWidth="100" preserveRatio="true">
                            <image>
                                <Image url="@../images/dlsulogo.png" />
                            </image>
                        </ImageView>

                        <!-- Title and Subtitle -->
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <Label styleClass="title" text="Join Animo Found" />
                                <Label styleClass="subtitle" text="Sign up to report or claim lost items." />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Signup Form Container -->
                <VBox alignment="CENTER" styleClass="form-container">
                    <children>
                        <!-- Signup Form Section -->
                        <VBox alignment="CENTER" styleClass="form-section" spacing="20">
                            <children>
                                <Label styleClass="form-title" text="Sign Up" />

                                <!-- Full Name Field -->
                                <VBox styleClass="input-group">
                                    <children>
                                        <Label styleClass="input-label" text="👤 Full Name" />
                                        <TextField fx:id="fullNameField"
                                                   promptText="Enter your full name"
                                                   styleClass="custom-textfield" />
                                    </children>
                                </VBox>

                                <!-- ID Number Field -->
                                <VBox styleClass="input-group">
                                    <children>
                                        <Label styleClass="input-label" text="🆔 ID Number" />
                                        <TextField fx:id="idNumberField"
                                                   promptText="Enter your ID number"
                                                   styleClass="custom-textfield" />
                                    </children>
                                </VBox>

                                <!-- Email Field -->
                                <VBox styleClass="input-group">
                                    <children>
                                        <Label styleClass="input-label" text="📧 Email" />
                                        <TextField fx:id="emailField"
                                                   promptText="Enter your email address"
                                                   styleClass="custom-textfield" />
                                    </children>
                                </VBox>

                                <!-- Password Field -->
                                <VBox styleClass="input-group">
                                    <children>
                                        <Label styleClass="input-label" text="🔒 Password" />
                                        <PasswordField fx:id="passwordField"
                                                       promptText="Create a password"
                                                       styleClass="custom-textfield" />
                                    </children>
                                </VBox>

                                <!-- Confirm Password Field -->
                                <VBox styleClass="input-group">
                                    <children>
                                        <Label styleClass="input-label" text="🔒 Confirm Password" />
                                        <PasswordField fx:id="confirmPasswordField"
                                                       promptText="Confirm your password"
                                                       styleClass="custom-textfield" />
                                    </children>
                                </VBox>

                                <!-- Signup Button -->
                                <Button fx:id="signupButton"
                                        mnemonicParsing="false"
                                        onAction="#handleSignup"
                                        styleClass="signup-button"
                                        text="✓ Create Account"
                                        maxWidth="Infinity" />

                                <!-- Back to Login Link -->
                                <Button fx:id="backToLoginButton"
                                        mnemonicParsing="false"
                                        onAction="#handleBackToLogin"
                                        styleClass="link-button"
                                        text="← Already have an account? Login" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>

        <!-- Footer -->
        <VBox alignment="CENTER" styleClass="footer-section">
            <children>
                <Label styleClass="footer-text" text="© 2025 Animo Found. All rights reserved." />
            </children>
        </VBox>

        <!-- Spacer to push content to center -->
        <Region VBox.vgrow="ALWAYS" />
    </children>
</VBox>