<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ClaimController"
            prefWidth="1920.0" prefHeight="1080.0"
            fitToWidth="true"
            styleClass="scroll-pane"
            stylesheets="@claim-style.css">

    <VBox spacing="0" styleClass="main-container">

        <!-- Header - Full Width -->
        <HBox alignment="CENTER_LEFT" styleClass="header-container">
            <Label text="🔍 Animo Found" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="🔔" style="-fx-font-size: 16px;"/>
        </HBox>

        <!-- Main Content - Centered Container -->
        <VBox spacing="20" styleClass="content-container" alignment="CENTER">

            <!-- Back Button - Constrained Width, Left Aligned -->
            <HBox alignment="CENTER_LEFT" styleClass="back-button-container">
                <Button text="← Back to listings" fx:id="backButton" onAction="#goBack"
                        styleClass="back-button"/>
            </HBox>

            <!-- STATE 1: Initial Item Card with Waiting Status -->
            <VBox fx:id="mainItemCard" spacing="15" styleClass="item-card">

                <!-- Status Header -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label fx:id="statusIndicator" text="●" styleClass="status-indicator,status-waiting"/>
                    <Label fx:id="statusLabel" text="Available for Claim"
                           styleClass="status-label"/>
                </HBox>

                <!-- Item Title -->
                <Label fx:id="itemName" text="Loading..."
                       style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

                <!-- Main Content Layout -->
                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- Left: Image -->
                    <VBox alignment="CENTER" styleClass="image-container">
                        <ImageView fx:id="itemImage" fitWidth="200" fitHeight="150"
                                   preserveRatio="true" styleClass="item-image"/>
                        <Label text="Item Image"
                               styleClass="image-overlay"/>
                    </VBox>

                    <!-- Right: Details -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <Label fx:id="itemDesc"
                               text="Loading item description..."
                               wrapText="true" styleClass="item-details"/>

                        <!-- Location Icon + Text -->
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="📍" style="-fx-font-size: 14px;"/>
                            <Label fx:id="itemLocation" text="Loading location..."
                                   styleClass="item-details"/>
                        </HBox>

                        <!-- Date Icon + Text -->
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="🕒" style="-fx-font-size: 14px;"/>
                            <Label fx:id="itemDateTime" text="Loading date..."
                                   styleClass="item-details"/>
                        </HBox>

                        <!-- Founder Icon + Text -->
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="👤" style="-fx-font-size: 14px;"/>
                            <Label fx:id="founderName" text="Loading user info..."
                                   styleClass="founder-info"/>
                        </HBox>

                        <!-- Email Icon + Text -->
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="✉" style="-fx-font-size: 14px;"/>
                            <Label fx:id="founderEmail" text="Loading email..."
                                   styleClass="founder-info"/>
                        </HBox>
                    </VBox>

                </HBox>

                <!-- Claim Button - Centered -->
                <HBox alignment="CENTER" styleClass="button-container">
                    <Button fx:id="claimButton" text="👤 Request Claim"
                            onAction="#requestClaim" styleClass="claim-button"
                            prefWidth="200"/>
                </HBox>

            </VBox>

            <!-- STATE 2: Claim Request Received Section -->
            <VBox fx:id="claimRequestSection" spacing="15" visible="true"
                  styleClass="claim-request-section">

                <!-- Section Header -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Claim Request Received"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="actionRequiredLabel" text="⚠ Action Required"
                           styleClass="action-required-label"/>
                </HBox>



                <!-- Action Buttons -->
                <HBox spacing="10" alignment="CENTER" styleClass="button-container">
                    <Button fx:id="confirmButton" text="✓ Confirm Claim"
                            onAction="#confirmClaim" styleClass="confirm-button"/>
                    <Button fx:id="messageButton" text="💬 Message"
                            onAction="#sendMessage" styleClass="message-button"/>
                </HBox>

            </VBox>

            <!-- STATE 3: Success Transition Icon -->
            <VBox alignment="CENTER" spacing="0" visible="true" styleClass="success-icon-container">
                <Label text="✓" styleClass="success-checkmark"/>
            </VBox>

            <!-- STATE 3: Success Section -->
            <VBox fx:id="claimedSection" spacing="15" visible="true"
                  styleClass="success-section" alignment="CENTER">

                <Label text="Item Successfully Claimed"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #155724; -fx-text-alignment: center;"/>

                <Label fx:id="successLabel"
                       text="This item has been claimed and the finder has been notified. Thank you for using Animo Found!"
                       wrapText="true" styleClass="success-message" textAlignment="CENTER"/>

                <!-- Claimed Date with Dot -->
                <HBox spacing="5" alignment="CENTER">
                    <Label text="●" style="-fx-text-fill: #6c757d; -fx-font-size: 12px;"/>
                    <Label text="Processing..." styleClass="success-date"/>
                </HBox>

            </VBox>

        </VBox>

        <!-- Footer - Full Width -->
        <VBox alignment="CENTER" styleClass="footer-container">

            <!-- Animo Found Logo/Title -->
            <Label text="🔍 Animo Found" styleClass="footer-title"/>

            <!-- Subtitle -->
            <Label text="Connecting lost items with their owners"
                   styleClass="footer-subtitle" style="-fx-padding: 5 0 15 0;"/>

            <!-- Footer Links -->
            <HBox spacing="30" alignment="CENTER" styleClass="footer-links-container">
                <Label text="Privacy Policy" styleClass="footer-link"/>
                <Label text="Terms of Service" styleClass="footer-link"/>
                <Label text="Contact Support" styleClass="footer-link"/>
            </HBox>

            <!-- Copyright -->
            <Label text="© 2025 Animo Found. All rights reserved."
                   styleClass="footer-copyright" style="-fx-padding: 15 0 0 0;"/>

        </VBox>

    </VBox>

</ScrollPane>